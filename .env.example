# 環境変数の例（値は設定しないこと。変数名のみ記載する）
# .env にコピーして値を設定する: cp .env.example .env
# ⚠️ .env は絶対にコミットしない

# Gemini API キー（本番運用時に設定する）
GEMINI_API_KEY=

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# Google Drive の共有フォルダ ID
DRIVE_FOLDER_ID=folder1

# Gemini 問題生成のデフォルト教科
GEMINI_TOPIC=算数

# Gemini 問題生成のデフォルト学年
GEMINI_GRADE=3

# 認証モード（mock: テスト用固定ユーザー / google: 将来の Google OAuth 対応）
AUTH_MODE=mock
